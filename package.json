{
  "name": "sisu-plus",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Mateusz Pasek",
    "email": "contact@matt-pasek.dev",
    "url": "https://matt-pasek.dev",
    "github": "https://github.com/matt-pasek"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matt-pasek/sisu-plus"
  },
  "packageManager": "bun@1.3.13",
  "description": "A better UI for Sisu, the student information system used in Finland.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --config vite.sw.config.ts --watch\" \"vite build --config vite.content.config.ts --watch\"",
    "build": "vite build --config vite.sw.config.ts && vite build --config vite.content.config.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "generate:apis": "bun run scripts/generate-apis.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.62.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "bun": "^1.3.13",
    "concurrently": "^9.2.1",
    "ogl": "^1.0.11",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.277",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.6"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
