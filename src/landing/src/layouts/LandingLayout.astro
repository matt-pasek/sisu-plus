---
import '@/app/global.css';
import '@landing/styles/base.css';
import AnalyticsIsland from '@landing/components/AnalyticsIsland';
import {
  buildCanonicalUrl,
  buildHreflangLinks,
  buildLandingJsonLd,
  buildOpenGraphImageUrl,
  LANDING_OG_IMAGE_ALT,
} from '@/landing/landingSeo';

const { locale, kind, metadata, route } = Astro.props;
const alternates = buildHreflangLinks(kind);
const ogImage = buildOpenGraphImageUrl();
---

<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <meta name="theme-color" content="#0d0d11" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="canonical" href={buildCanonicalUrl(route)} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sisu+" />
    <meta property="og:title" content={metadata.title} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:url" content={buildCanonicalUrl(route)} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={LANDING_OG_IMAGE_ALT} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metadata.title} />
    <meta name="twitter:description" content={metadata.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={LANDING_OG_IMAGE_ALT} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(buildLandingJsonLd(locale))} />
  </head>
  <body>
    <slot />
    <AnalyticsIsland client:load />
  </body>
</html>
