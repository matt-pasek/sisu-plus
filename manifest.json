{
  "manifest_version": 3,
  "name": "Sisu+",
  "version": "0.1.0",
  "description": "A better UI for LUT Sisu",
  "permissions": ["storage", "webRequest"],
  "host_permissions": ["https://sisu.lut.fi/*", "https://moodle.lut.fi/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://sisu.lut.fi/*"],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://sisu.lut.fi/*"]
    }
  ]
}
